# =============================================================================
# M-Pesa
# =============================================================================
# Copia estas variaveis para o .env da tua aplicacao Laravel.
# So MPESA_API_KEY e MPESA_PUBLIC_KEY sao obrigatorias; o resto tem defaults
# prontos para o sandbox. Depois de editar o .env corre: php artisan config:clear
# =============================================================================

# --- Obrigatorias (do portal M-Pesa) ----------------------------------------
# A chave publica e uma linha longa de base64 — mantem-na entre aspas duplas.
MPESA_API_KEY=
MPESA_PUBLIC_KEY=""

# Em alternativa, deixa MPESA_PUBLIC_KEY vazia e aponta para um ficheiro:
# MPESA_PUBLIC_KEY_PATH=/caminho/para/public_key.txt

# --- Ambiente ----------------------------------------------------------------
# development (sandbox) | production
MPESA_ENVIRONMENT=development

# --- Dados do comerciante ----------------------------------------------------
# 171717 e o shortcode do sandbox. Em producao usa o teu (ex.: 903153).
MPESA_SERVICE_PROVIDER_CODE=171717
MPESA_ORIGIN=developer.mpesa.vm.co.mz

# --- Reversao (so necessario para reversal()) --------------------------------
MPESA_INITIATOR_IDENTIFIER=
MPESA_SECURITY_CREDENTIAL=

# --- Ligacao (opcional) ------------------------------------------------------
# Deixa vazio para usar os defaults resolvidos pelo ambiente.
# MPESA_HOST=
# MPESA_PORT=
# MPESA_TIMEOUT=90
# MPESA_CONNECT_TIMEOUT=30
# MPESA_VERIFY_SSL=true
