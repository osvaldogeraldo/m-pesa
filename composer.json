{
  "name": "brilliant_mind/m-pesa",
  "description": "MPesa package for laravel",
  "license": "MIT",
  "keywords": [
    "brilliant_mind",
    "mpesa",
    "mozambique",
    "laravel"
  ],
  "autoload": {
    "psr-4": {
      "BrilliantMind\\MPesa\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BrilliantMind\\MPesa\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Osvaldo Manjate",
      "email": "osvaldogeraldo34@gmail.com",
      "role": "Maintainer"
    },
    {
      "name": "Paulo Maculuve",
      "email": "paulomaculuve758@gmail.com",
      "role": "Original Author"
    }
  ],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "ext-openssl": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^11.3"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": [
        "BrilliantMind\\MPesa\\Providers\\MPesaServiceProvider"
      ],
      "aliases": {
        "MPesa": "BrilliantMind\\MPesa\\Facades\\MPesa",
        "Mpesa": "BrilliantMind\\MPesa\\Facades\\MPesa"
      }
    }
  }
}
